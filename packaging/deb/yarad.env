# yarad daemon environment. systemd reads this via EnvironmentFile.
# Every value here is also the built-in default — uncomment to override.
# Full reference: README.md "Configuration".

# --- listener ---
#YARAD_ADDR=0.0.0.0
#YARAD_PORT=8079

# --- rules ---
# The rolling bundle fetched by `yarad fetch-rules` (default cache /var/cache/yarad).
# A precompiled .yac wins over YARAD_RULES_DIR. This is the recommended setup for
# the .deb: run `yarad fetch-rules` (or the maintenance cron) to refresh it.
YARAD_RULES=/var/cache/yarad/compiled.yac
# Alternatively compile a directory of your own *.yar/*.yara on boot + SIGHUP:
#YARAD_RULES_DIR=/var/lib/yarad/rules
# Cache dir fetch-rules writes to (must match the -cache-dir you fetch with):
#YARAD_CACHE_DIR=/var/cache/yarad
# Flag the ruleset stale (rules_stale=1, /ready 503) past this age (seconds):
#YARAD_RULES_MAX_AGE=172800

# --- auth (recommended for non-trusted networks) ---
# Shared secret for /scan (and /metrics + /version when YARAD_METRICS_AUTH=1).
# Unset = OPEN /scan (trusted-network deployment, logged loudly at startup).
#YARAD_TOKEN=
#YARAD_METRICS_AUTH=0

# --- live IOC feeds (off unless enabled) ---
#YARAD_URLHAUS=1
#YARAD_THREATFOX=1
#YARAD_FEODO=1
#YARAD_MALWAREBAZAAR=1

# --- effort / backpressure ---
#YARAD_EFFORT=auto
#YARAD_MAX_INFLIGHT=32
#YARAD_MAX_BODY=33554432

# --- verdict cache TTL (seconds) ---
#YARAD_CACHE_TTL=3600
