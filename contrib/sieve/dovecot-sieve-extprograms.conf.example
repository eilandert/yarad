# Dovecot config to enable the Sieve `execute` extension used by yarad-scan.sieve.
# Merge into your Dovecot config (e.g. /etc/dovecot/conf.d/90-sieve-extprograms.conf)
# and reload dovecot.

# Load the extprograms plugin and expose vnd.dovecot.execute to scripts.
plugin {
  sieve_plugins = sieve_extprograms

  # Make the extension available to user/global scripts. (Without this,
  # `require "vnd.dovecot.execute"` in a script is rejected.)
  sieve_global_extensions = +vnd.dovecot.execute

  # Programs callable via `execute :pipe "name"` live here. Install
  # yarad-scan-wrapper into this directory (0755, owned by the run-as user).
  sieve_execute_bin_dir = /usr/lib/dovecot/sieve-execute

  # editheader (addheader/X-Yara-Scan) — optional, drop the require + addheader
  # lines from the script if you don't want header tagging.
  sieve_extensions = +editheader

  # Run yarad-scan.sieve before the user's own script, at delivery, for everyone.
  # (Use sieve_after instead if a match should still respect user filing rules.)
  sieve_before = /etc/dovecot/sieve/yarad-scan.sieve
}
