{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping yarad /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["yarad", "mail", "malware", "yara"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(yarad_scans_total, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "title": "yarad — mail malware scanner",
  "uid": "yarad-overview",
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Rules loaded",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "targets": [ { "expr": "yarad_rules{instance=~\"$instance\"}", "legendFormat": "{{instance}}" } ]
    },
    {
      "type": "stat",
      "title": "Ruleset age",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "expr": "yarad_rules_age_seconds{instance=~\"$instance\"}", "legendFormat": "{{instance}}" } ]
    },
    {
      "type": "stat",
      "title": "Stale rulesets",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [ { "expr": "sum(yarad_rules_stale{instance=~\"$instance\"})", "legendFormat": "stale" } ]
    },
    {
      "type": "stat",
      "title": "Scan rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [ { "expr": "sum(rate(yarad_scans_total{instance=~\"$instance\"}[5m]))", "legendFormat": "scans/s" } ]
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [ { "expr": "sum(rate(yarad_cache_hits_total{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(yarad_cache_hits_total{instance=~\"$instance\"}[5m]) + rate(yarad_cache_misses_total{instance=~\"$instance\"}[5m])), 0.001)", "legendFormat": "hit ratio" } ]
    },
    {
      "type": "stat",
      "title": "Match rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [ { "expr": "sum(rate(yarad_matches_total{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(yarad_scans_total{instance=~\"$instance\"}[5m])), 0.001)", "legendFormat": "matched" } ]
    },
    {
      "type": "row",
      "title": "Request path",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries",
      "title": "Requests/s by outcome",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum(rate(yarad_scans_total{instance=~\"$instance\"}[5m]))", "legendFormat": "scans" },
        { "expr": "sum(rate(yarad_matches_total{instance=~\"$instance\"}[5m]))", "legendFormat": "matches" },
        { "expr": "sum(rate(yarad_errors_total{instance=~\"$instance\"}[5m]))", "legendFormat": "errors" },
        { "expr": "sum(rate(yarad_busy_total{instance=~\"$instance\"}[5m]))", "legendFormat": "busy (rejected)" },
        { "expr": "sum(rate(yarad_canceled_total{instance=~\"$instance\"}[5m]))", "legendFormat": "canceled" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cache: hits / misses / coalesced / evictions",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(yarad_cache_hits_total{instance=~\"$instance\"}[5m]))", "legendFormat": "hits" },
        { "expr": "sum(rate(yarad_cache_misses_total{instance=~\"$instance\"}[5m]))", "legendFormat": "misses" },
        { "expr": "sum(rate(yarad_cache_coalesced_total{instance=~\"$instance\"}[5m]))", "legendFormat": "coalesced" },
        { "expr": "sum(rate(yarad_cache_evictions_total{instance=~\"$instance\"}[5m]))", "legendFormat": "evictions" }
      ]
    },
    {
      "type": "row",
      "title": "Scan channels & extraction",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "libyara scans/s by channel",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(yarad_raw_channel_scans_total{instance=~\"$instance\"}[5m]))", "legendFormat": "raw" },
        { "expr": "sum(rate(yarad_stream_channel_scans_total{instance=~\"$instance\"}[5m]))", "legendFormat": "stream" },
        { "expr": "sum(rate(yarad_marker_channel_scans_total{instance=~\"$instance\"}[5m]))", "legendFormat": "marker" },
        { "expr": "sum(rate(yarad_bigfile_scans_total{instance=~\"$instance\"}[5m]))", "legendFormat": "bigfile" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Extraction by carrier (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(yarad_extract_macro_docs_total{instance=~\"$instance\"}[5m]))", "legendFormat": "macro docs" },
        { "expr": "sum(rate(yarad_extract_pdf_total{instance=~\"$instance\"}[5m]))", "legendFormat": "pdf" },
        { "expr": "sum(rate(yarad_extract_rtf_total{instance=~\"$instance\"}[5m]))", "legendFormat": "rtf" },
        { "expr": "sum(rate(yarad_extract_archive_total{instance=~\"$instance\"}[5m]))", "legendFormat": "archive" },
        { "expr": "sum(rate(yarad_extract_onenote_total{instance=~\"$instance\"}[5m]))", "legendFormat": "onenote" },
        { "expr": "sum(rate(yarad_extract_xlm_fold_total{instance=~\"$instance\"}[5m]))", "legendFormat": "xlm fold" },
        { "expr": "sum(rate(yarad_extract_encrypted_total{instance=~\"$instance\"}[5m]))", "legendFormat": "encrypted" },
        { "expr": "sum(rate(yarad_extract_ext_mismatch_total{instance=~\"$instance\"}[5m]))", "legendFormat": "ext mismatch" }
      ]
    },
    {
      "type": "row",
      "title": "Rules, reload & feeds",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "type": "timeseries",
      "title": "Rule reloads/s (success / failure)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(yarad_reload_success_total{instance=~\"$instance\"}[15m]))", "legendFormat": "success" },
        { "expr": "sum(rate(yarad_reload_failure_total{instance=~\"$instance\"}[15m]))", "legendFormat": "failure" }
      ]
    },
    {
      "type": "timeseries",
      "title": "abuse.ch feed lookups & hits (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(yarad_urlhaus_lookups_total{instance=~\"$instance\"}[5m]))", "legendFormat": "urlhaus lookups" },
        { "expr": "sum(rate(yarad_urlhaus_hits_total{instance=~\"$instance\"}[5m]))", "legendFormat": "urlhaus hits" },
        { "expr": "sum(rate(yarad_malwarebazaar_lookups_total{instance=~\"$instance\"}[5m]))", "legendFormat": "mbazaar lookups" },
        { "expr": "sum(rate(yarad_malwarebazaar_hits_total{instance=~\"$instance\"}[5m]))", "legendFormat": "mbazaar hits" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auto effort level",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "min": 0, "max": 10 } },
      "targets": [ { "expr": "yarad_effort_auto_level{instance=~\"$instance\"}", "legendFormat": "{{instance}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Feed/refresh failures (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "sum(rate(yarad_urlhaus_refresh_failures_total{instance=~\"$instance\"}[1h]))", "legendFormat": "urlhaus" },
        { "expr": "sum(rate(yarad_malwarebazaar_refresh_failures_total{instance=~\"$instance\"}[1h]))", "legendFormat": "mbazaar" }
      ]
    },
    { "type": "row", "title": "ICAP (optional listener)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 } },
    {
      "type": "timeseries",
      "title": "ICAP requests/s by outcome",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "description": "Only nonzero when YARAD_ICAP_ADDR is set. REQMOD/RESPMOD vs OPTIONS, and the infected subset (403 replacement sent).",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(yarad_icap_requests_total{instance=~\"$instance\"}[5m]))", "legendFormat": "requests" },
        { "expr": "sum(rate(yarad_icap_options_total{instance=~\"$instance\"}[5m]))", "legendFormat": "options" },
        { "expr": "sum(rate(yarad_icap_infected_total{instance=~\"$instance\"}[5m]))", "legendFormat": "infected" }
      ]
    },
    {
      "type": "stat",
      "title": "ICAP infection ratio",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "description": "Share of ICAP REQMOD/RESPMOD requests that matched >=1 rule (403 replacement sent). Excludes OPTIONS.",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        { "expr": "sum(rate(yarad_icap_infected_total{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(yarad_icap_requests_total{instance=~\"$instance\"}[5m])), 0.001)", "legendFormat": "infected ratio" }
      ]
    }
  ]
}
